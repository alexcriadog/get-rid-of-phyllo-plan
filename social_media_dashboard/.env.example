# Copy to `.env` and fill in:
#   cp .env.example .env

# Your Camaleonic API key. Issued by the operator (us). Server-side only —
# never expose to the browser.
CAMALEONIC_API_KEY=cmlk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Connect-tool / API base URL.
CAMALEONIC_BASE_URL=https://smconnector.camaleonicanalytics.com

# Your workspace slug as registered with Camaleonic.
WORKSPACE_SLUG=demo

# Any random string. Used to sign the session cookie.
SESSION_SECRET=change-me-to-a-random-32-byte-string

# Local port for the dashboard.
PORT=4000
