MONGO_URL=mongodb://localhost:27017/connector_ui
CONNECTOR_API_URL=http://localhost:3000

# ── Operator login (Auth.js) ──────────────────────────────────────────────
# AUTH_SECRET signs the operator session JWT issued at /login. connect-tool
# validates the SAME cookie to gate /data-guide, so its AUTH_SECRET must be
# byte-identical to this one (see connect-tool/.env.example) — otherwise
# /data-guide bounces every logged-in operator back to /login.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=
# Operator accounts — JSON array of {email, name, passwordHash} (bcrypt).
# Invalid JSON silently parses to [] (lib/operator-users.ts), i.e. nobody can
# log in, so validate it after editing.
# e.g. [{"email":"ops@example.com","name":"Ops","passwordHash":"$2a$10$REPLACE"}]
OPERATOR_USERS=
