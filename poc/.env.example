NODE_ENV=development
DATABASE_URL="mysql://connector_user:connector_pw@localhost:3306/connector"
MONGO_URL="mongodb://localhost:27017/connector_ui"
REDIS_URL="redis://localhost:6379"
API_PORT=3000

# Meta app (for webhook signature verification only in PoC)
META_APP_ID=<your_app_id>
META_APP_SECRET=<your_app_secret>
META_WEBHOOK_VERIFY_TOKEN=<random_32_char_string>

# Outbound webhooks (events we send TO customer endpoints).
# Default behaviour: require https in production, allow http in dev/staging.
# Override explicitly with `true|false|1|0|yes|no|on|off`. Recommended:
# always keep this `true` in prod so a misconfigured client never gets
# their secrets POSTed over plaintext.
WEBHOOKS_REQUIRE_HTTPS=true

# Outbound delivery worker concurrency (BullMQ). Raise to drain a deep
# backlog faster (e.g. a large data.* fan-out). Range 1-64, default 4.
WEBHOOK_DELIVERY_CONCURRENCY=4

# Retention sweep (cron, 03:00 UTC daily — see webhooks-retention.service.ts).
# Both values must be positive integers; 0 or negative are rejected at boot.
# - InboundWebhookLog: every row older than N days is deleted (irrespective
#   of processed status). 30 d is a sensible default for incident debugging.
# - WebhookDelivery: only delivered/abandoned rows older than N days are
#   deleted. pending/failed rows stay forever so an operator can retry them.
INBOUND_LOG_RETENTION_DAYS=30
OUTBOUND_DELIVERY_RETENTION_DAYS=90
# - ApiCallLog (MySQL api_call_log): one row per outbound platform request —
#   the dominant write volume. Deleted after N days (calledAt is indexed).
API_CALL_LOG_RETENTION_DAYS=30
# - Mongo event_log + raw_platform_responses: append-only diagnostic logs.
#   Both purged after N days (event_log.emitted_at / raw.fetchedAt). Raw
#   bodies are bulky, so this defaults lower than the SQL logs.
MONGO_RAW_RETENTION_DAYS=14
# Set to `true` for the first prod run so the sweep REPORTS without
# deleting; double-check the counts before unset/false. Applies to ALL
# sweeps above (inbound, outbound, api_call_log, mongo raw).
WEBHOOKS_RETENTION_DRY_RUN=false

# Local crypto for tokens at rest (PoC only — replace with KMS in prod)
LOCAL_AES_KEY=<openssl_rand_hex_32>
# Key rotation (decrypt-fallback only): comma-separated list of RETIRED hex
# keys. To rotate: move the current LOCAL_AES_KEY value into this list and
# set LOCAL_AES_KEY to a fresh `openssl rand -hex 32`. Old ciphertext still
# decrypts via the retired key; each token re-seals with the new active key
# on its next refresh, so retired keys age out — then drop them from here.
# Leave empty when not rotating. NOT a substitute for KMS in real prod.
LOCAL_AES_KEYS_OLD=

# YouTube — Google Cloud project credentials (Data API v3 + Analytics API v2).
# See docs/youtube-oauth-setup.md for the full Google Cloud Console walkthrough.
GOOGLE_CLIENT_ID=<your_oauth_client_id>
GOOGLE_CLIENT_SECRET=<your_oauth_client_secret>
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback/youtube
# Optional — only used for public-channel lookups that don't need OAuth.
YOUTUBE_API_KEY=<your_youtube_api_key>
# Google Ads API developer token (Basic Access, ~2 days approval at
# https://ads.google.com/aw/apicenter). Leaving empty disables the
# `ads` product for YouTube; the worker records success with an
# empty AdsSnapshot until the token is provided.
GOOGLE_ADS_DEVELOPER_TOKEN=

# Twitch — register at https://dev.twitch.tv/console/apps. Helix calls send
# Client-Id + Bearer; OAuth token refresh needs the client secret too. The
# redirect URI is configured on the connect-tool side (see connect-tool/.env).
TWITCH_CLIENT_ID=<your_twitch_client_id>
TWITCH_CLIENT_SECRET=<your_twitch_client_secret>

# Where the OAuth callback should send the browser after exchanging the code.
# Defaults to http://localhost:3001 (Next admin dev port). In prod, set to
# the public origin where the admin UI is served.
ADMIN_UI_BASE_URL=http://localhost:3001

# ── connect-tool integration ─────────────────────────────────────────
# Bearer token gating /admin/connect/seed and /admin/connect/discover.
# connect-tool MUST present `Authorization: Bearer <this>`.
# Unset → guard is permissive (dev-only fallback). Generate with:
#   openssl rand -hex 32
CONNECT_TOOL_SECRET=
# Public URL where connect-tool is reachable (used by docker-compose).
CONNECT_TOOL_PUBLIC_URL=http://localhost:3002
POC_ADMIN_URL=http://localhost:3001/admin

# Ops
SCHEDULER_TICK_MS=30000
WORKER_CONCURRENCY=1
REDIS_NS=connector-poc

# LinkedIn (Camaleonic Analytics Connector app — Community Management API)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
