generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                   BigInt   @id @default(autoincrement())
  platform             String
  canonicalUserId      String   @map("canonical_user_id")
  // Connection-flow discriminator — part of the account uniqueness key so the
  // SAME canonical Instagram identity can coexist as two rows: one connected
  // via Instagram Login ('ig_direct'), one via Facebook Login ('fb_login').
  // Every other platform resolves to 'default' (one connection per identity).
  connectionFlow       String   @default("default") @map("connection_flow")
  handle               String?
  displayName          String?  @map("display_name")
  status               String   @default("ready")
  syncTier             String   @default("standard") @map("sync_tier")
  owningOrganizationId String   @default("demo") @map("owning_organization_id")
  // Multi-tenant scoping. NOT NULL after the backfill migration. Existing
  // accounts are reassigned to the auto-created "demo" workspace so legacy
  // single-tenant deployments keep working unchanged.
  workspaceId          String   @map("workspace_id")
  // Optional end-user identifier carried in from the SDK token. Lets a
  // client correlate the connected account back to their own user record.
  endUserId            String?  @map("end_user_id")
  // True when the account was created via a `cmlk_test_*` SDK token.
  // Test-mode accounts share the same storage as live ones but don't fire
  // outbound webhooks (so clients can develop against real OAuth without
  // hammering their own webhook endpoint with fake events).
  isTest               Boolean  @default(false) @map("is_test")
  // Per-platform extension bag — `{ business_id?, page_id?, channel_id?, advertiser_id?, ... }`.
  // Adapters read from here via their own context builders. Nullable for backwards-compat.
  metadata             Json?
  connectedAt          DateTime @default(now()) @map("connected_at")
  disconnectedAt       DateTime? @map("disconnected_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tokens    OAuthToken[]
  syncJobs  SyncJob[]
  overrides AccountCadenceOverride[]
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, platform, canonicalUserId, connectionFlow], map: "accounts_ws_platform_canonical_flow_key")
  @@index([workspaceId, platform])
  @@index([workspaceId, endUserId])
  @@map("accounts")
}

model OAuthToken {
  id                     BigInt   @id @default(autoincrement())
  accountId              BigInt   @unique @map("account_id")
  accessTokenCiphertext  Bytes    @map("access_token_ciphertext")
  // For Meta family we also persist the user-level token alongside the
  // primary (page) token. ads_read needs a USER token; everything else
  // (pages_read_user_content, page insights) uses the PAGE token. Null on
  // platforms that don't have the page/user split.
  userAccessTokenCiphertext Bytes? @map("user_access_token_ciphertext")
  // TikTok and other rotating-refresh-token platforms keep their refresh secret here.
  // Meta long-lived tokens leave it null.
  refreshTokenCiphertext Bytes?   @map("refresh_token_ciphertext")
  scopes                 Json
  expiresAt              DateTime? @map("expires_at")
  lastRefreshedAt        DateTime? @map("last_refreshed_at")
  createdAt              DateTime @default(now()) @map("created_at")
  account                Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("oauth_tokens")
}

/// Append-only history of every OAuth token sealed for an account (on connect
/// and on each refresh). NO relation to Account on purpose, so it SURVIVES
/// account deletion/overwrite — the break-glass recovery store read by
/// scripts/decrypt-token.ts. Tokens stay encrypted (same AES-GCM bytes as
/// OAuthToken); keyVersion records which active key sealed each row so a
/// retiring key can be re-sealed before it is dropped from the keyring.
model OAuthTokenHistory {
  id                        BigInt    @id @default(autoincrement())
  accountId                 BigInt    @map("account_id")
  canonicalUserId           String?   @map("canonical_user_id")
  platform                  String?
  connectionFlow            String?   @map("connection_flow")
  accessTokenCiphertext     Bytes     @map("access_token_ciphertext")
  userAccessTokenCiphertext Bytes?    @map("user_access_token_ciphertext")
  refreshTokenCiphertext    Bytes?    @map("refresh_token_ciphertext")
  scopes                    Json?
  expiresAt                 DateTime? @map("expires_at")
  keyVersion                String    @map("key_version")
  source                    String
  capturedAt                DateTime  @default(now()) @map("captured_at")

  @@index([canonicalUserId, platform, connectionFlow, capturedAt], map: "oauth_token_history_canonical_idx")
  @@index([accountId, capturedAt], map: "oauth_token_history_account_idx")
  @@map("oauth_token_history")
}

model SyncJob {
  id            BigInt   @id @default(autoincrement())
  accountId     BigInt   @map("account_id")
  product       String
  status        String   @default("idle")
  priority      String   @default("NORMAL")
  nextRunAt     DateTime? @map("next_run_at")
  lastSuccessAt DateTime? @map("last_success_at")
  lastAttemptAt DateTime? @map("last_attempt_at")
  lastError     String?  @db.Text @map("last_error")
  failureCount  Int      @default(0) @map("failure_count")
  // Per-(account, product) settings bag — admin-editable knobs that the
  // worker merges over env-vars and built-in defaults. Examples:
  //   engagement_new -> { lookbackDays: 60, maxPostsPerSync: 200 }
  //   comments       -> { videoLookback: 100, perVideo: 30 }
  // null means "use defaults".
  settings      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, product])
  @@index([status, nextRunAt])
  @@map("sync_jobs")
}

model Cadence {
  platform               String
  product                String
  defaultIntervalSeconds Int     @map("default_interval_seconds")
  refreshIntervalSeconds Int?     @map("refresh_interval_seconds")
  refreshWindowDays      Int?     @map("refresh_window_days")
  updatedAt              DateTime @updatedAt @map("updated_at")
  @@id([platform, product])
  @@map("cadences")
}

model AccountCadenceOverride {
  accountId               BigInt   @map("account_id")
  product                 String
  overrideIntervalSeconds Int      @map("override_interval_seconds")
  reason                  String?
  createdAt               DateTime @default(now()) @map("created_at")
  expiresAt               DateTime? @map("expires_at")
  account                 Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([accountId, product])
  @@map("account_cadences")
}

model InboundWebhookLog {
  id              BigInt   @id @default(autoincrement())
  platform        String
  eventId         String   @map("event_id")
  receivedAt      DateTime @default(now()) @map("received_at")
  signatureValid  Boolean  @map("signature_valid")
  accountResolved Boolean  @default(false) @map("account_resolved")
  payloadSnippet  String?  @db.Text @map("payload_snippet")
  processed       Boolean  @default(false)

  @@unique([platform, eventId])
  @@index([receivedAt])
  @@map("inbound_webhook_log")
}

// ─── Multi-tenancy & SaaS surface ──────────────────────────────────────────
//
// A Workspace is a tenant. Every Account belongs to one. Each Workspace has:
//   - ApiKeys: long-lived bearer credentials the client's backend uses to
//     call /v1/* and to mint short-lived SDK tokens.
//   - WorkspaceSecret: symmetric HMAC key used to sign + verify SDK JWTs
//     handed to the browser. Stored encrypted via AesLocalService.
//   - WebhookEndpoints: outbound notification targets the client registers.
//
// Created in the multi_tenancy_foundation migration. A row with slug="demo"
// is auto-seeded so existing pre-multi-tenant accounts keep functioning.

model Workspace {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  // Brandable theme JSON read by connect.camaleonic.io. Shape documented in
  // the spec; null means "use platform defaults".
  branding  Json?
  // Per-workspace platform + product allow-list. Shape:
  // Record<platform,string[]>, e.g. {"tiktok":["identity","audience"]}.
  // NOT NULL since the Phase C migration — every workspace MUST have an
  // explicit allow-list. The migration backfills pre-existing rows with the
  // full catalog (preserving previous "unrestricted" behaviour). Admins
  // tighten via PATCH /admin/workspaces/:slug/products.
  products  Json
  // Operator-set per-product webhook delivery cadence. Shape:
  // Record<product, "immediate" | "hourly" | "daily">. Missing key → the
  // safe default "immediate" (operator dials hourly/daily for noisy
  // products like engagement_new or stories). Snapshot products
  // (identity, audience, engagement_deep, ratings, ads) ignore the value
  // — there's no meaningful items_added delta to digest, so they always
  // fire on each successful sync. PATCHed from the admin UI via
  // PATCH /admin/workspaces/:slug/webhook-cadence.
  webhookCadence Json? @map("webhook_cadence")
  // Sec-4: per-workspace origin allow-list for SDK-token postMessage scoping.
  // JSON array of canonical web origins, e.g.
  // ["https://app.example.com","https://example.com"]. The mint endpoint
  // embeds this as the token's signed `origins` claim; connect-tool validates
  // the popup's ?origin against it at /api/oauth/start and only ever
  // postMessages the OAuth result back to a listed origin. null/absent means
  // "no origin restriction" (legacy behaviour — the SDK-supplied origin is
  // trusted as-is), so the column is additive + nullable and zero-downtime.
  // Edited from the admin UI via PATCH /admin/workspaces/:slug/allowed-origins.
  allowedOrigins Json? @map("allowed_origins")
  planTier  String   @default("standard") @map("plan_tier")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  apiKeys          ApiKey[]
  secret           WorkspaceSecret?
  webhookEndpoints WebhookEndpoint[]
  accounts         Account[]
  apiCredentials   ApiCredential[]

  @@map("workspaces")
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  // Public prefix shown in dashboards/logs (e.g. "cmlk_live_abcd"). Never
  // by itself sufficient to authenticate.
  keyPrefix   String    @map("key_prefix")
  // SHA-256 hex digest of the full key. We verify by hashing the inbound
  // Bearer string and comparing in constant time against this.
  keyHash     String    @unique @map("key_hash")
  scope       String    @default("read_write")
  label       String?
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([keyPrefix])
  @@map("api_keys")
}

model WorkspaceSecret {
  id               String    @id @default(cuid())
  workspaceId      String    @unique @map("workspace_id")
  // AES-256-GCM ciphertext of the HMAC-SHA256 secret used to sign SDK JWTs.
  // Layout matches AesLocalService: iv(12) || tag(16) || ciphertext.
  secretCiphertext Bytes     @map("secret_ciphertext")
  createdAt        DateTime  @default(now()) @map("created_at")
  rotatedAt        DateTime? @map("rotated_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_secrets")
}

// Basic-auth credentials for the public data API. The consumer sends
// `Authorization: Basic base64(client_id:client_secret)` (InsightIQ-style).
// We store only the SHA-256 of the secret and verify in constant time.
model ApiCredential {
  id               String    @id @default(cuid())
  workspaceId      String    @map("workspace_id")
  // Public client id (Basic-auth username). Safe to show in dashboards/logs.
  clientId         String    @unique @map("client_id")
  // SHA-256 hex digest of the client secret (Basic-auth password).
  clientSecretHash String    @map("client_secret_hash")
  label            String?
  lastUsedAt       DateTime? @map("last_used_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("api_credentials")
}

model WebhookEndpoint {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  url         String   @db.Text
  // Signing secret returned ONCE on creation. Used to compute the
  // X-Camaleonic-Signature header. Stored plaintext intentionally — losing
  // it requires regenerating; we do not need to retrieve it after creation
  // but operators inspecting deliveries may need it.
  secret      String
  // JSON array of event types subscribed to. MySQL has no native String[],
  // so we use Json. Allowed values are validated in the service layer.
  events      Json
  active      Boolean  @default(true)
  description String?
  // Wire format for this endpoint's deliveries:
  //   "camaleonic" (default) — our native envelope + X-Camaleonic-Signature.
  //   "standard"             — InsightIQ-compatible thin events +
  //                            Webhook-Signatures (HMAC-SHA256 of raw body).
  format      String   @default("camaleonic")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  deliveries     WebhookDelivery[]
  pendingEvents  PendingWebhookEvent[]

  @@index([workspaceId])
  @@map("webhook_endpoints")
}

// Hourly/daily digest buffer for data-update webhooks.
//
// When a sync_job finishes with items_added > 0 AND the workspace's
// webhookCadence for that product is "hourly" or "daily", the worker
// upserts a row here keyed by (endpoint, account, product). Subsequent
// syncs in the same window increment items_added atomically and append
// to sampleIds (capped at 20).
//
// The cron in webhooks-digest.service.ts flushes:
//   - cadence=hourly buckets where firstSeenAt < now() - 1h    (every :05)
//   - cadence=daily  buckets where firstSeenAt < now() - 24h   (09:05 UTC)
//
// onDelete: Cascade — if the endpoint is removed, drop the pending buffer.
model PendingWebhookEvent {
  id          String   @id @default(cuid())
  endpointId  String   @map("endpoint_id")
  accountId   BigInt   @map("account_id")
  product     String
  // "hourly" | "daily" — the cron flushes by this column.
  cadence     String
  itemsAdded  Int      @default(0) @map("items_added")
  // JSON array of platform_content_id strings; capped at 20 entries by the
  // dispatcher. Used to populate sample_ids in the digest payload.
  sampleIds   Json     @default("[]") @map("sample_ids")
  // When the first new item in this bucket landed — becomes window_start in
  // the digest payload and is what the cron's cutoff compares against.
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @updatedAt @map("last_seen_at")
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([endpointId, accountId, product])
  @@index([cadence, firstSeenAt])
  @@map("pending_webhook_events")
}

model WebhookDelivery {
  id               String    @id @default(cuid())
  endpointId       String    @map("endpoint_id")
  event            String
  payload          Json
  attempts         Int       @default(0)
  // pending | delivered | failed | abandoned
  status           String    @default("pending")
  lastResponseCode Int?      @map("last_response_code")
  lastError        String?   @db.Text @map("last_error")
  // First 4 KB of the LAST attempt's response body (truncated). Used by
  // admin "show payload + response" to debug client-side rejections.
  responseBody     String?   @db.Text @map("response_body")
  // Headers of the LAST attempt's response (small JSON object).
  responseHeaders  Json?     @map("response_headers")
  // Round-trip time of the LAST attempt in milliseconds. Surfaces in the
  // endpoint health endpoint (Phase D) for p50/p95 latency.
  durationMs       Int?      @map("duration_ms")
  nextRetryAt      DateTime? @map("next_retry_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  deliveredAt      DateTime? @map("delivered_at")
  endpoint         WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

model ApiCallLog {
  id            BigInt   @id @default(autoincrement())
  platform      String
  endpoint      String
  method        String
  statusCode    Int      @map("status_code")
  durationMs    Int      @map("duration_ms")
  rateBucketKey String?  @map("rate_bucket_key")
  tokensBefore  Int?     @map("tokens_before")
  tokensAfter   Int?     @map("tokens_after")
  usageHeader   Json?    @map("usage_header")
  accountId     BigInt?  @map("account_id")
  product       String?
  /// True when the non-2xx is a documented "no data" outcome (e.g. Meta IG
  /// privacy-threshold subcode 2874010 — "Not enough users"). Dashboards
  /// exclude these from error counts; they remain visible in raw logs.
  expected      Boolean  @default(false)
  calledAt      DateTime @default(now()) @map("called_at")

  @@index([calledAt])
  @@index([platform, calledAt])
  @@map("api_call_log")
}
