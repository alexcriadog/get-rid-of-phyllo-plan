generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                   BigInt   @id @default(autoincrement())
  platform             String
  canonicalUserId      String   @map("canonical_user_id")
  handle               String?
  displayName          String?  @map("display_name")
  status               String   @default("ready")
  syncTier             String   @default("standard") @map("sync_tier")
  owningOrganizationId String   @default("demo") @map("owning_organization_id")
  // Multi-tenant scoping. NOT NULL after the backfill migration. Existing
  // accounts are reassigned to the auto-created "demo" workspace so legacy
  // single-tenant deployments keep working unchanged.
  workspaceId          String   @map("workspace_id")
  // Optional end-user identifier carried in from the SDK token. Lets a
  // client correlate the connected account back to their own user record.
  endUserId            String?  @map("end_user_id")
  // Per-platform extension bag — `{ business_id?, page_id?, channel_id?, advertiser_id?, ... }`.
  // Adapters read from here via their own context builders. Nullable for backwards-compat.
  metadata             Json?
  connectedAt          DateTime @default(now()) @map("connected_at")
  disconnectedAt       DateTime? @map("disconnected_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tokens    OAuthToken[]
  syncJobs  SyncJob[]
  overrides AccountCadenceOverride[]
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, platform, canonicalUserId])
  @@index([workspaceId, platform])
  @@index([workspaceId, endUserId])
  @@map("accounts")
}

model OAuthToken {
  id                     BigInt   @id @default(autoincrement())
  accountId              BigInt   @unique @map("account_id")
  accessTokenCiphertext  Bytes    @map("access_token_ciphertext")
  // For Meta family we also persist the user-level token alongside the
  // primary (page) token. ads_read needs a USER token; everything else
  // (pages_read_user_content, page insights) uses the PAGE token. Null on
  // platforms that don't have the page/user split.
  userAccessTokenCiphertext Bytes? @map("user_access_token_ciphertext")
  // TikTok and other rotating-refresh-token platforms keep their refresh secret here.
  // Meta long-lived tokens leave it null.
  refreshTokenCiphertext Bytes?   @map("refresh_token_ciphertext")
  scopes                 Json
  expiresAt              DateTime? @map("expires_at")
  lastRefreshedAt        DateTime? @map("last_refreshed_at")
  createdAt              DateTime @default(now()) @map("created_at")
  account                Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("oauth_tokens")
}

model SyncJob {
  id            BigInt   @id @default(autoincrement())
  accountId     BigInt   @map("account_id")
  product       String
  status        String   @default("idle")
  priority      String   @default("NORMAL")
  nextRunAt     DateTime? @map("next_run_at")
  lastSuccessAt DateTime? @map("last_success_at")
  lastAttemptAt DateTime? @map("last_attempt_at")
  lastError     String?  @db.Text @map("last_error")
  failureCount  Int      @default(0) @map("failure_count")
  // Per-(account, product) settings bag — admin-editable knobs that the
  // worker merges over env-vars and built-in defaults. Examples:
  //   engagement_new -> { lookbackDays: 60, maxPostsPerSync: 200 }
  //   comments       -> { videoLookback: 100, perVideo: 30 }
  // null means "use defaults".
  settings      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, product])
  @@index([status, nextRunAt])
  @@map("sync_jobs")
}

model Cadence {
  platform               String
  product                String
  defaultIntervalSeconds Int     @map("default_interval_seconds")
  updatedAt              DateTime @updatedAt @map("updated_at")
  @@id([platform, product])
  @@map("cadences")
}

model AccountCadenceOverride {
  accountId               BigInt   @map("account_id")
  product                 String
  overrideIntervalSeconds Int      @map("override_interval_seconds")
  reason                  String?
  createdAt               DateTime @default(now()) @map("created_at")
  expiresAt               DateTime? @map("expires_at")
  account                 Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([accountId, product])
  @@map("account_cadences")
}

model InboundWebhookLog {
  id              BigInt   @id @default(autoincrement())
  platform        String
  eventId         String   @map("event_id")
  receivedAt      DateTime @default(now()) @map("received_at")
  signatureValid  Boolean  @map("signature_valid")
  accountResolved Boolean  @default(false) @map("account_resolved")
  payloadSnippet  String?  @db.Text @map("payload_snippet")
  processed       Boolean  @default(false)

  @@unique([platform, eventId])
  @@index([receivedAt])
  @@map("inbound_webhook_log")
}

// ─── Multi-tenancy & SaaS surface ──────────────────────────────────────────
//
// A Workspace is a tenant. Every Account belongs to one. Each Workspace has:
//   - ApiKeys: long-lived bearer credentials the client's backend uses to
//     call /v1/* and to mint short-lived SDK tokens.
//   - WorkspaceSecret: symmetric HMAC key used to sign + verify SDK JWTs
//     handed to the browser. Stored encrypted via AesLocalService.
//   - WebhookEndpoints: outbound notification targets the client registers.
//
// Created in the multi_tenancy_foundation migration. A row with slug="demo"
// is auto-seeded so existing pre-multi-tenant accounts keep functioning.

model Workspace {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  // Brandable theme JSON read by connect.camaleonic.io. Shape documented in
  // the spec; null means "use platform defaults".
  branding  Json?
  planTier  String   @default("standard") @map("plan_tier")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  apiKeys          ApiKey[]
  secret           WorkspaceSecret?
  webhookEndpoints WebhookEndpoint[]
  accounts         Account[]

  @@map("workspaces")
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  // Public prefix shown in dashboards/logs (e.g. "cmlk_live_abcd"). Never
  // by itself sufficient to authenticate.
  keyPrefix   String    @map("key_prefix")
  // SHA-256 hex digest of the full key. We verify by hashing the inbound
  // Bearer string and comparing in constant time against this.
  keyHash     String    @unique @map("key_hash")
  scope       String    @default("read_write")
  label       String?
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([keyPrefix])
  @@map("api_keys")
}

model WorkspaceSecret {
  id               String    @id @default(cuid())
  workspaceId      String    @unique @map("workspace_id")
  // AES-256-GCM ciphertext of the HMAC-SHA256 secret used to sign SDK JWTs.
  // Layout matches AesLocalService: iv(12) || tag(16) || ciphertext.
  secretCiphertext Bytes     @map("secret_ciphertext")
  createdAt        DateTime  @default(now()) @map("created_at")
  rotatedAt        DateTime? @map("rotated_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_secrets")
}

model WebhookEndpoint {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  url         String   @db.Text
  // Signing secret returned ONCE on creation. Used to compute the
  // X-Camaleonic-Signature header. Stored plaintext intentionally — losing
  // it requires regenerating; we do not need to retrieve it after creation
  // but operators inspecting deliveries may need it.
  secret      String
  // JSON array of event types subscribed to. MySQL has no native String[],
  // so we use Json. Allowed values are validated in the service layer.
  events      Json
  active      Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  deliveries WebhookDelivery[]

  @@index([workspaceId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id               String    @id @default(cuid())
  endpointId       String    @map("endpoint_id")
  event            String
  payload          Json
  attempts         Int       @default(0)
  // pending | delivered | failed | abandoned
  status           String    @default("pending")
  lastResponseCode Int?      @map("last_response_code")
  lastError        String?   @db.Text @map("last_error")
  nextRetryAt      DateTime? @map("next_retry_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  deliveredAt      DateTime? @map("delivered_at")
  endpoint         WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

model ApiCallLog {
  id            BigInt   @id @default(autoincrement())
  platform      String
  endpoint      String
  method        String
  statusCode    Int      @map("status_code")
  durationMs    Int      @map("duration_ms")
  rateBucketKey String?  @map("rate_bucket_key")
  tokensBefore  Int?     @map("tokens_before")
  tokensAfter   Int?     @map("tokens_after")
  usageHeader   Json?    @map("usage_header")
  accountId     BigInt?  @map("account_id")
  product       String?
  /// True when the non-2xx is a documented "no data" outcome (e.g. Meta IG
  /// privacy-threshold subcode 2874010 — "Not enough users"). Dashboards
  /// exclude these from error counts; they remain visible in raw logs.
  expected      Boolean  @default(false)
  calledAt      DateTime @default(now()) @map("called_at")

  @@index([calledAt])
  @@index([platform, calledAt])
  @@map("api_call_log")
}
