# Observability agent config — copy to .env on the connector EC2.
#
# Central observability EC2's VPC-private IP (Prometheus remote_write :9090 +
# Loki push :3100). The connector box reaches it over the AWS VPC.
OBSERVABILITY_EC2_PRIVATE_IP=172.31.43.195

# Selects agents/prometheus-agent-${ENV}.yml + agents/promtail-${ENV}.yml.
ENV=prod

# Human label for this box (kept for parity with the org's other agents).
INSTANCE_NAME=connector-prod
