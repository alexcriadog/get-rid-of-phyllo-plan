# Caddy config for the EC2 deploy. Auto-obtains a Let's Encrypt cert via
# HTTP-01 challenge for the AWS hostname; renews automatically.

smconnector.camaleonicanalytics.com {
	encode gzip

	# /internal/* is a service-to-service zone (sdk-token verify, workspace
	# branding, end-user account lists). It must NEVER be reachable from the
	# public internet. Deny it at the edge BEFORE the /api/poc/* passthrough
	# below (handle blocks evaluate in source order). The api also guards
	# /internal/* server-side (InternalAuthGuard) — this is defence in depth.
	handle /api/poc/internal/* {
		respond 403
	}

	# Admin API surface (operator-only). The admin dashboard at /admin* calls
	# these endpoints from the browser at /api/poc/admin/*, so lock them at the
	# edge with the SAME basic_auth as the /admin* block below — same origin +
	# realm means the browser reuses the operator's credentials for those XHRs.
	# MUST precede the /api/poc/* passthrough (handle blocks match in source
	# order). connect-tool's server-to-server seed (POST /admin/connect/seed)
	# reaches the API directly over the compose network — not through Caddy — so
	# it is unaffected here (and is independently bearer-guarded server-side).
	# `uri strip_prefix /api/poc` keeps the API path as /admin/* after the gate.
	handle /api/poc/admin* {
		basic_auth {
			alex $2y$12$FRUN6ZltRlZsFygdSj0ED.ExibDXMV7zrDqAbflTRg6Cel0Oc7XRq
		}
		uri strip_prefix /api/poc
		reverse_proxy api:3000
	}

	# POC backend exposed under /api/poc. /api/poc/admin/* is gated above; the
	# rest (e.g. /v1/* proxied helpers the client dashboard uses) passes through.
	handle_path /api/poc/* {
		reverse_proxy api:3000
	}

	# Public SaaS API surface. Bearer cmlk_(live|test)_* auth, workspace-
	# scoped per request. Lives directly on the API container — no path
	# rewrite, the controllers are already mounted at /v1/*.
	handle /v1/* {
		reverse_proxy api:3000
	}

	# Admin dashboard — operator-only. basic_auth enabled (Sec-4 hardening): the
	# admin surface mutates security-critical config (workspace origin allow-
	# lists, product scopes, live API keys), so it must not be anonymously
	# reachable. Same user+hash as the /api/poc/admin* gate above so the browser
	# authenticates once and reuses the credentials for the dashboard's XHRs.
	# Rotate with: htpasswd -bnBC 12 "" '<newpw>'  (or caddy hash-password).
	handle /admin* {
		basic_auth {
			alex $2y$12$FRUN6ZltRlZsFygdSj0ED.ExibDXMV7zrDqAbflTRg6Cel0Oc7XRq
		}
		reverse_proxy web:3001
	}

	# Client dashboard — clients log in with their workspace API key,
	# see their own connected accounts + manage webhooks.
	handle /client* {
		reverse_proxy web:3001
	}

	# Client-dashboard's own API routes (login / logout / proxy → connector).
	handle /api/client* {
		reverse_proxy web:3001
	}

	# Admin dashboard's own server-side API routes (Next /pages/api/admin/*).
	# These run ON the web container and attach CONNECT_TOOL_SECRET server-side
	# to reach ConnectToolGuard-protected connector endpoints (e.g. the
	# token-debug proxy). They return operator-only data (plaintext OAuth
	# tokens), so gate them with the SAME basic_auth as /admin* — and route to
	# web, not the default connect-tool handler (which would 404). MUST precede
	# the catch-all `handle {}` at the bottom.
	handle /api/admin* {
		basic_auth {
			alex $2y$12$FRUN6ZltRlZsFygdSj0ED.ExibDXMV7zrDqAbflTRg6Cel0Oc7XRq
		}
		reverse_proxy web:3001
	}

	# Public account profile pages (e.g. /account/2, /account/2/posts).
	handle /account* {
		reverse_proxy web:3001
	}

	# Public feed (alias of web's `/`, exposed under a unique path so it
	# doesn't collide with connect-tool's `/`).
	handle /feed* {
		reverse_proxy web:3001
	}

	# Public watchlist (FB Pages monitor — PPCA, app-token only).
	handle /watchlist* {
		reverse_proxy web:3001
	}

	# Internal admin web API (Mongo-proxy for comments).
	handle /api/comments* {
		reverse_proxy web:3001
	}

	# Both Next apps emit assets at /_next/*; we disambiguate by giving
	# connect-tool a build-time assetPrefix='/connect'. So:
	#   /_next/*         → web (no prefix, vanilla Next paths)
	#   /connect/_next/* → connect-tool (its prefixed assets + hydration)
	handle /_next/* {
		reverse_proxy web:3001
	}
	handle /connect/_next/* {
		reverse_proxy connect-tool:3002
	}

	# Everything else (/, /api/oauth/*, /facebook/pages, /confirm/*,
	# /success, /api/seed-pages, /api/seed-confirm) → connect-tool.
	handle {
		reverse_proxy connect-tool:3002
	}
}

# verify-youtube — YouTube OAuth verification UI. Single-purpose throwaway
# app served on its own subdomain (cleaner for Google's reviewer than
# path-prefixing under smconnector.*). Tear down after Google approves:
# remove this whole block, run `./tools/deploy.sh`, drop the DNS A record.
yt-connector.camaleonicanalytics.com {
	encode gzip

	# All paths go to verify-youtube. The app serves its own /privacy,
	# /terms, /verified/*, /api/oauth/*, and the favicon.
	reverse_proxy verify-youtube:3003
}
