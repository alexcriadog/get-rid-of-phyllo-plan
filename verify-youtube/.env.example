# verify-youtube — environment variables.
#
# This app exists solely to pass Google's OAuth verification for YouTube
# sensitive scopes. After Google approves the OAuth client, the same
# client_id is reused from the main company app. This service can then
# be torn down from the EC2 (see tools/EC2-DEPLOY.md, "Removal").
#
# Dev: copy to .env and fill in. Prod: managed via docker compose env.

# OAuth client from the existing GROP-Youtube Google Cloud project.
# These are the SAME values as in connect-tool/.env — we reuse the same
# OAuth Web client, just with an additional authorized redirect URI for
# https://yt-connector.camaleonicanalytics.com/api/oauth/callback/youtube
# (added in Google Cloud Console alongside the existing smconnector ones).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Ads API developer token. Issued by Google after applying for
# Basic Access at https://ads.google.com/aw/apicenter (requires a
# Manager / MCC account; ~2 business days review). Without this token,
# the adwords scope card on /verified will render an error message.
# Same value app-wide; not per-user.
GOOGLE_ADS_DEVELOPER_TOKEN=

# Public base URL where this app serves. Used to build the redirect_uri
# query parameter in the OAuth authorize URL.
#   - Local dev: http://localhost:3003
#   - EC2:       https://yt-connector.camaleonicanalytics.com
PUBLIC_BASE_URL=http://localhost:3003

# Optional. If unset, redirect_uri is computed as ${PUBLIC_BASE_URL}/api/oauth/callback/youtube.
# Set explicitly only if Google's authorized redirect URI must differ
# (e.g. path-rewriting reverse proxy).
# GOOGLE_REDIRECT_URI=

NODE_ENV=development
