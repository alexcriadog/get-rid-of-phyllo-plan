# connect-tool — TRANSIENT OAuth helper for the POC.
# Copy to .env and fill in. Each platform's credentials come from its
# developer console (Meta App, Google Cloud, TikTok BC, Threads App).

# ── POC API contract ──────────────────────────────────────────────────────
POC_API_URL=http://api:3000        # internal hostname when run via docker compose
CONNECT_TOOL_SECRET=               # 32 random bytes hex — must match POC's env

# ── Redis (OAuth session store) ───────────────────────────────────────────
# Backs the transient OAuth session bridge (token + preview between the
# callback and the seed POST). Sharing POC's Redis makes connect-tool
# stateless so it can run behind a load balancer. Under docker compose this
# is the internal hostname; for local `npm run dev` use redis://localhost:6379.
REDIS_URL=redis://redis:6379

# Public base URL of THIS service. Used to build redirect_uri values that
# match what's registered in each platform's developer console.
PUBLIC_BASE_URL=http://localhost:3002

# ── Meta (Facebook + Instagram via Page picker) ──────────────────────────
META_APP_ID=
META_APP_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/api/oauth/callback/facebook when empty.
META_REDIRECT_URI=

# ── Google (YouTube + YouTube Analytics) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/api/oauth/callback/youtube when empty.
GOOGLE_REDIRECT_URI=

# ── TikTok Business (BC v1.3) ─────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# ── Threads (separate app id from Meta) ───────────────────────────────────
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=

# ── Twitch (Helix API + OAuth) ─────────────────────────────────────────────
# Register an app at https://dev.twitch.tv/console/apps. Copy Client ID +
# Client Secret. Add `${PUBLIC_BASE_URL}/api/oauth/callback/twitch` as a
# redirect URI in the app settings.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/api/oauth/callback/twitch when empty.
TWITCH_REDIRECT_URI=

# ── Instagram API with Instagram Login (IG-direct) ────────────────────────
# Instagram API with Instagram Login (IG-direct) — the Instagram product
# inside the Meta app has its OWN app id/secret (not META_APP_ID).
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Optional override; defaults to <base>/api/oauth/callback/instagram_direct
INSTAGRAM_REDIRECT_URI=
# Opt-in rollout flag for the IG-direct flow
IG_DIRECT_ENABLED=

# LinkedIn OAuth. Redirect URI defaults to
# ${PUBLIC_BASE_URL}/api/oauth/callback/linkedin when empty — it must
# EXACTLY match a Redirect URL registered in the LinkedIn app Auth tab.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# ── X (Twitter) — LOGIN-ONLY OAuth 2.0 + PKCE ─────────────────────────────
# Register an app at https://developer.x.com (free tier is enough: the only
# API call is GET /2/users/me at connect time). In the app's "User
# authentication settings": enable OAuth 2.0, type "Web App" (confidential),
# and register `${PUBLIC_BASE_URL}/api/oauth/callback/twitter` as a Callback
# URI. Scopes requested: users.read tweet.read (no offline.access — the
# token is allowed to lapse; X data comes from scraping, not the API).
#
# Credentials alone are NOT enough to see the X tile: a workspace must also
# opt in via PATCH /admin/workspaces/:slug/products {"twitter":["identity"]}.
# That step, and why scraping must join on canonical_user_id and not on the
# handle, are in docs/07-platforms/twitter.md.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/api/oauth/callback/twitter when empty.
TWITTER_REDIRECT_URI=
